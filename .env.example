# ============================================================================
# BNO LLM Assistant - environment configuration
# ============================================================================
# Copy this file to ".env" and fill in real values on the server:
#     cp .env.example .env
# The app loads .env automatically on startup (see config.py).
# NEVER commit the real .env (it is already in .gitignore).

# --- Security (REQUIRED in production) --------------------------------------
# Generate a strong random key, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Default admin account created on first startup. Change the password!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Account policy
# Open self-registration is OFF by default - admins create accounts. Set to true
# only if you want anyone who can reach the app to create their own login.
ALLOW_REGISTRATION=false
# Minimum password length for new passwords / resets.
MIN_PASSWORD_LENGTH=8
# Login brute-force protection: max failed attempts per IP within the window.
LOGIN_MAX_ATTEMPTS=10
LOGIN_WINDOW_MINUTES=5

# --- Server binding ---------------------------------------------------------
# Bind 0.0.0.0 so users on the corporate network / AVD can reach the app.
# Default app port is 9000. On the BNO server Ollama may already use 9000 —
# run ./scripts/configure_bno_server.sh to switch the app to 8000 automatically.
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=9000

# --- LLM provider -----------------------------------------------------------
# "ollama" runs models locally on this server (recommended for on-prem - nothing
# leaves the network). "openai" sends questions/document context to OpenAI's API
# over the internet - only use this if that's cleared for BNO's data policy.
LLM_PROVIDER=ollama

# Where Ollama is listening. Default is localhost:11434.
# On the BNO server Ollama may be on port 9000 — use configure_bno_server.sh
# or set: OLLAMA_BASE_URL=http://localhost:9000
OLLAMA_BASE_URL=http://localhost:11434

# Optional: override the models the app uses.
# OLLAMA_EMBEDDING_MODEL=hf.co/CompendiumLabs/bge-base-en-v1.5-gguf
# Default language model is qwen2.5:7b (best quality, needs a GPU to be fast).
# On a CPU-only server, use the 3b version instead for much faster answers:
# OLLAMA_LANGUAGE_MODEL=qwen2.5:3b

# --- OpenAI (only used if LLM_PROVIDER=openai, or if vision extraction below
# is enabled) ------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# gpt-4o-mini: cheap/fast, has vision. gpt-4o: pricier, best for detailed
# image/diagram comprehension.
# OPENAI_LANGUAGE_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Image/diagram vision extraction (optional) ------------------------------
# When enabled, images embedded in uploaded PDFs are described by an OpenAI
# vision model during indexing, so questions about diagrams/screenshots can be
# answered even though normal text Q&A stays on local Ollama (LLM_PROVIDER
# above). Requires OPENAI_API_KEY to be set above.
# NOTE: this sends the document's images (not the surrounding text) to
# OpenAI's API over the internet. Leave disabled until that is cleared for
# BNO's data policy.
# ENABLE_VISION_EXTRACTION=true
# gpt-4o reads small/dense diagram text far more reliably than gpt-4o-mini.
# OPENAI_VISION_MODEL=gpt-4o
# Skip embedded images smaller than this (px) - filters out logos/icons.
# VISION_MIN_IMAGE_DIM=150
# Hard cap on images described per document (cost/time control).
# VISION_MAX_IMAGES_PER_DOC=20

# --- Uploads / indexing -----------------------------------------------------
# Max upload size in MB. Files are indexed in the background, so large files
# won't time out the request; the ceiling is processing time + disk/RAM.
MAX_FILE_SIZE_MB=100
# Chunks embedded per Ollama call during indexing (higher = faster, more RAM).
EMBED_BATCH_SIZE=32

# --- Vector database --------------------------------------------------------
VECTOR_DB_TYPE=chromadb

# --- CORS (only needed if UI is served from a different host than the API) ---
# Comma-separated list. Same-origin access does NOT need this.
# CORS_ORIGINS=http://10.237.238.218:9000
